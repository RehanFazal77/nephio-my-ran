apiVersion: kpt.dev/v1
kind: Kptfile
metadata: # kpt-merge: /oai-ran
  name: oai-ran
  annotations:
    config.kubernetes.io/local-config: "true"
    internal.kpt.dev/upstream-identifier: 'kpt.dev|Kptfile|default|oai-ran'
upstream:
  type: git
  git:
    repo: https://github.com/RehanFazal77/nephio-blueprints-approachB.git
    directory: workloads/oai-ran
    ref: main
upstreamLock:
  type: git
  git:
    repo: https://github.com/RehanFazal77/nephio-blueprints-approachB.git
    directory: workloads/oai-ran
    ref: main
    commit: dd80ad3922489e109f7b8afd2e8fecbb8884af1d
info:
  description: |
    OAI RAN network blueprint for BYOH clusters.
    Generates IPClaims and NADs automatically via interface-fn + nad-fn pipeline.
    IPAM controller allocates IPs from IPPrefix pools.
  readinessGates:
  - conditionType: config.injection.WorkloadCluster.workload-cluster
  - conditionType: req.nephio.org/v1alpha1.Interface.n2
  - conditionType: req.nephio.org/v1alpha1.Interface.n3
  - conditionType: req.nephio.org/v1alpha1.Interface.ru
pipeline:
  mutators:
  - image: docker.io/nephio/interface-fn:v2.0.0
    configMap:
      debug: "true"
  - image: docker.io/nephio/nad-fn:latest
    configMap:
      debug: "true"
status:
  conditions:
  - type: config.injection.WorkloadCluster.workload-cluster
    status: "True"
    message: injected resource "my-ran" from cluster
    reason: ConfigInjected
  - message: update resource
    reason: req.nephio.org/v1alpha1.Interface.n2
    status: "False"
    type: ipam.resource.nephio.org/v1alpha1.IPClaim.gnb-n2-ipv4
  - message: update resource
    reason: req.nephio.org/v1alpha1.Interface.n3
    status: "False"
    type: ipam.resource.nephio.org/v1alpha1.IPClaim.gnb-n3-ipv4
  - message: update resource
    reason: req.nephio.org/v1alpha1.Interface.ru
    status: "False"
    type: ipam.resource.nephio.org/v1alpha1.IPClaim.gnb-ru-ipv4
  - message: create initial resource
    reason: req.nephio.org/v1alpha1.Interface.n2
    status: "False"
    type: k8s.cni.cncf.io/v1.NetworkAttachmentDefinition.gnb-n2
  - message: create initial resource
    reason: req.nephio.org/v1alpha1.Interface.n3
    status: "False"
    type: k8s.cni.cncf.io/v1.NetworkAttachmentDefinition.gnb-n3
  - message: create initial resource
    reason: req.nephio.org/v1alpha1.Interface.ru
    status: "False"
    type: k8s.cni.cncf.io/v1.NetworkAttachmentDefinition.gnb-ru
  - message: update for condition
    status: "False"
    type: req.nephio.org/v1alpha1.Interface.n2
  - message: update for condition
    status: "False"
    type: req.nephio.org/v1alpha1.Interface.n3
  - message: update for condition
    status: "False"
    type: req.nephio.org/v1alpha1.Interface.ru
